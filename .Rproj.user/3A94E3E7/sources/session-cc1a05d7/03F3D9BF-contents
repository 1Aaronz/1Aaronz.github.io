# - Find the top 5 markets in terms of the total `beer_floz` of *NATURAL LIGHT*.

# Answer for Q2a
top5_markets <- beer_mkts %>%
  group_by(market) %>%
  summarise(total_floz = sum(beer_floz)) %>%
  arrange(desc(total_floz)) %>%
  slice(1:5)

